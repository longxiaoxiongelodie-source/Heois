{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MiniStar",
  "version": "1.0.0",
  "identifier": "com.baiyu.ministar",
  "build": {
    "beforeDevCommand": "bash ../../launchers/start.sh",
    "devUrl": "http://127.0.0.1:8080/mobile.html",
    "frontendDist": "../../../chat"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MiniStar",
        "width": 430,
        "height": 932,
        "minWidth": 390,
        "minHeight": 780,
        "resizable": true,
        "fullscreen": false,
        "url": "mobile.html"
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ]
  }
}
